# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/makicore?schema=public"

# JWT
JWT_SECRET="makicore-super-secret-key-change-in-production"
JWT_EXPIRATION="8h"
JWT_REFRESH_SECRET="makicore-refresh-secret-key-change-in-production"
JWT_REFRESH_EXPIRATION="7d"

# App
PORT=4001
NODE_ENV=development
API_PREFIX=api/v1

# CORS
CORS_ORIGIN=http://localhost:4000

# WebSocket
WS_PORT=4002

# Brand Colors (for reference)
# BRAND_DARK_GREEN=#1B3A2D
# BRAND_ORANGE_GOLD=#D4842A
# BRAND_CREAM=#F5E6C8
